<%- include('partials/head') %>
<body class="font-body-md text-on-surface min-h-screen flex flex-col items-center justify-center p-gutter"
      style="-webkit-font-smoothing: antialiased; background-color: #f7f7f5;">

  <!-- Atmospheric blobs -->
  <div class="fixed inset-0 pointer-events-none overflow-hidden -z-10">
    <div class="absolute -top-24 -right-24 w-96 h-96 rounded-full blur-3xl" style="background:rgba(113,42,226,0.05)"></div>
    <div class="absolute -bottom-24 -left-24 w-80 h-80 rounded-full blur-3xl" style="background:rgba(174,40,38,0.05)"></div>
  </div>

  <main class="w-full max-w-[440px] animate-fade-in">

    <!-- Branding -->
    <div class="text-center mb-xl">
      <a href="/" class="font-display text-display-mobile md:text-display font-bold text-tsubaki-red tracking-tight mb-xs block">
        Kizuna Nihongo
      </a>
      <p class="font-body-md text-on-surface-variant ma-spacing"><%= t('common.tagline') %></p>
    </div>

    <div class="glass-card rounded-xl p-md md:p-lg space-y-md">

      <div class="flex flex-col items-center text-center space-y-sm pb-sm">
        <span class="material-symbols-outlined text-tsubaki-red" style="font-size:48px" id="page-icon">lock_open</span>
        <h2 class="font-h2 text-h2 text-on-surface"><%= t('auth.reset_heading') %></h2>
      </div>

      <!-- Server-side error (PKCE flow failed / expired code) -->
      <% if (error) { %>
      <div class="flex items-center gap-base px-md py-sm rounded-lg bg-error-container text-on-error-container font-caption" id="server-error">
        <span class="material-symbols-outlined text-[16px]">error</span>
        <%= error %>
      </div>
      <% } %>

      <!-- Client-side error (implicit flow issues) -->
      <div id="client-error" class="hidden flex items-center gap-base px-md py-sm rounded-lg bg-error-container text-on-error-container font-caption">
        <span class="material-symbols-outlined text-[16px]">error</span>
        <span id="client-error-text"></span>
      </div>

      <!-- ── PKCE: server already validated the code ── -->
      <% if (valid === true) { %>
      <form action="/reset-password" method="POST" class="space-y-md" id="reset-form-server">
        <div class="space-y-xs">
          <label class="font-label-md text-label-md text-on-surface-variant block" for="password"><%= t('auth.new_password') %></label>
          <div class="relative">
            <input id="password" name="password" type="password" placeholder="<%= t('auth.password_min') %>" autocomplete="new-password" required
              class="w-full bg-transparent border-b border-outline-variant focus:border-tsubaki-red focus:ring-0 transition-all duration-300 py-base px-0 font-body-md outline-none pr-8">
            <button id="toggle-password" type="button"
              class="absolute right-0 bottom-base text-on-surface-variant hover:text-tsubaki-red transition-colors">
              <span id="toggle-password-icon" class="material-symbols-outlined text-[20px]">visibility</span>
            </button>
          </div>
        </div>
        <div class="space-y-xs">
          <label class="font-label-md text-label-md text-on-surface-variant block" for="confirmPassword"><%= t('auth.confirm_password') %></label>
          <div class="relative">
            <input id="confirmPassword" name="confirmPassword" type="password" placeholder="<%= t('auth.confirm_placeholder') %>" autocomplete="new-password" required
              class="w-full bg-transparent border-b border-outline-variant focus:border-tsubaki-red focus:ring-0 transition-all duration-300 py-base px-0 font-body-md outline-none pr-8">
            <button id="toggle-confirm" type="button"
              class="absolute right-0 bottom-base text-on-surface-variant hover:text-tsubaki-red transition-colors">
              <span id="toggle-confirm-icon" class="material-symbols-outlined text-[20px]">visibility</span>
            </button>
          </div>
        </div>
        <div class="pt-sm">
          <button type="submit"
            class="w-full bg-tsubaki-red text-on-primary font-label-md text-label-md py-md rounded-lg shadow-sm hover:bg-primary transition-all duration-300 active:scale-[0.98]">
            <%= t('auth.reset_submit') %>
          </button>
        </div>
      </form>
      <% } %>

      <!-- ── Implicit: client JS will show this after detecting the hash ── -->
      <% if (valid === 'pending') { %>
      <div id="detecting-state" class="text-center py-sm">
        <span class="material-symbols-outlined text-on-surface-variant animate-spin" style="font-size:32px">progress_activity</span>
        <p class="font-caption text-on-surface-variant mt-sm"><%= t('auth.detecting') %></p>
      </div>

      <form id="reset-form-client" class="space-y-md hidden">
        <div class="space-y-xs">
          <label class="font-label-md text-label-md text-on-surface-variant block" for="password"><%= t('auth.new_password') %></label>
          <div class="relative">
            <input id="password" type="password" placeholder="<%= t('auth.password_min') %>" autocomplete="new-password" required
              class="w-full bg-transparent border-b border-outline-variant focus:border-tsubaki-red focus:ring-0 transition-all duration-300 py-base px-0 font-body-md outline-none pr-8">
            <button id="toggle-password" type="button"
              class="absolute right-0 bottom-base text-on-surface-variant hover:text-tsubaki-red transition-colors">
              <span id="toggle-password-icon" class="material-symbols-outlined text-[20px]">visibility</span>
            </button>
          </div>
        </div>
        <div class="space-y-xs">
          <label class="font-label-md text-label-md text-on-surface-variant block" for="confirmPassword"><%= t('auth.confirm_password') %></label>
          <div class="relative">
            <input id="confirmPassword" type="password" placeholder="<%= t('auth.confirm_placeholder') %>" autocomplete="new-password" required
              class="w-full bg-transparent border-b border-outline-variant focus:border-tsubaki-red focus:ring-0 transition-all duration-300 py-base px-0 font-body-md outline-none pr-8">
            <button id="toggle-confirm" type="button"
              class="absolute right-0 bottom-base text-on-surface-variant hover:text-tsubaki-red transition-colors">
              <span id="toggle-confirm-icon" class="material-symbols-outlined text-[20px]">visibility</span>
            </button>
          </div>
        </div>
        <div class="pt-sm">
          <button type="submit" id="submit-btn"
            class="w-full bg-tsubaki-red text-on-primary font-label-md text-label-md py-md rounded-lg shadow-sm hover:bg-primary transition-all duration-300 active:scale-[0.98]">
            <%= t('auth.reset_submit') %>
          </button>
        </div>
      </form>

      <!-- Dead-end: no token in hash either -->
      <div id="invalid-state" class="hidden text-center py-sm">
        <a href="/forgot-password" class="inline-flex items-center gap-xs font-label-md text-label-md text-tsubaki-red hover:underline">
          <span class="material-symbols-outlined text-[18px]">refresh</span>
          <%= t('auth.resend_reset') %>
        </a>
      </div>
      <% } %>

      <!-- Expired / invalid (PKCE code bad) -->
      <% if (valid === false) { %>
      <div class="text-center py-sm">
        <a href="/forgot-password" class="inline-flex items-center gap-xs font-label-md text-label-md text-tsubaki-red hover:underline">
          <span class="material-symbols-outlined text-[18px]">refresh</span>
          <%= t('auth.resend_reset') %>
        </a>
      </div>
      <% } %>

      <div class="text-center pt-sm">
        <a href="/login" class="inline-flex items-center gap-xs font-label-md text-label-md text-on-surface-variant hover:text-tsubaki-red transition-colors">
          <span class="material-symbols-outlined text-[18px]">arrow_back</span>
          <%= t('auth.back_to_login') %>
        </a>
      </div>

    </div>
  </main>

  <footer class="fixed bottom-gutter w-full text-center pointer-events-none">
    <p class="font-caption text-on-surface-variant opacity-60">
      <%= t('common.copyright') %>
    </p>
  </footer>

  <!-- Toggle visibility for PKCE server-rendered form -->
  <% if (valid === true) { %>
  <script>
    (function() {
      function makeToggle(btnId, inputId, iconId) {
        document.getElementById(btnId).addEventListener('click', function() {
          var input = document.getElementById(inputId);
          var icon  = document.getElementById(iconId);
          var shown = input.type === 'text';
          input.type = shown ? 'password' : 'text';
          icon.textContent = shown ? 'visibility' : 'visibility_off';
        });
      }
      makeToggle('toggle-password', 'password', 'toggle-password-icon');
      makeToggle('toggle-confirm',  'confirmPassword', 'toggle-confirm-icon');
    })();
  </script>
  <% } %>

  <!-- Implicit flow handler (when valid === 'pending') -->
  <% if (valid === 'pending') { %>
  <script src="https://cdn.jsdelivr.net/npm/@supabase/supabase-js@2/dist/umd/supabase.min.js"></script>
  <script>
  (function() {
    var SUPABASE_URL  = '<%= supabaseUrl %>';
    var SUPABASE_KEY  = '<%= supabaseKey %>';
    var MSG_SHORT     = '<%- t("errors.reset_pass_short") %>';
    var MSG_MISMATCH  = '<%- t("errors.reset_mismatch") %>';
    var MSG_EXPIRED   = '<%- t("errors.reset_expired") %>';
    var MSG_ERROR     = '<%- t("errors.unexpected") %>';
    var MSG_RESET     = '<%- t("auth.reset_submit") %>';
    var MSG_PROCESS   = '<%- t("auth.processing") %>';
    var MSG_INVALID   = '<%- t("errors.link_invalid") %>';

    var hash = window.location.hash.substring(1);
    var params = new URLSearchParams(hash);
    var accessToken  = params.get('access_token');
    var refreshToken = params.get('refresh_token');
    var type         = params.get('type');

    function showClientError(msg) {
      var el = document.getElementById('client-error');
      document.getElementById('client-error-text').textContent = msg;
      el.classList.remove('hidden');
      el.classList.add('flex');
    }

    if (accessToken && type === 'recovery') {
      document.getElementById('detecting-state').classList.add('hidden');
      document.getElementById('reset-form-client').classList.remove('hidden');

      function makeToggle(btnId, inputId, iconId) {
        document.getElementById(btnId).addEventListener('click', function() {
          var input = document.getElementById(inputId);
          var icon  = document.getElementById(iconId);
          var shown = input.type === 'text';
          input.type = shown ? 'password' : 'text';
          icon.textContent = shown ? 'visibility' : 'visibility_off';
        });
      }
      makeToggle('toggle-password', 'password', 'toggle-password-icon');
      makeToggle('toggle-confirm',  'confirmPassword', 'toggle-confirm-icon');

      document.getElementById('reset-form-client').addEventListener('submit', async function(e) {
        e.preventDefault();
        var password = document.getElementById('password').value;
        var confirm  = document.getElementById('confirmPassword').value;

        if (password.length < 8) { showClientError(MSG_SHORT); return; }
        if (password !== confirm) { showClientError(MSG_MISMATCH); return; }

        var btn = document.getElementById('submit-btn');
        btn.disabled = true;
        btn.textContent = MSG_PROCESS;

        try {
          var client = supabase.createClient(SUPABASE_URL, SUPABASE_KEY);
          var sessionResult = await client.auth.setSession({ access_token: accessToken, refresh_token: refreshToken });
          if (sessionResult.error) { showClientError(MSG_EXPIRED); btn.disabled = false; btn.textContent = MSG_RESET; return; }

          var updateResult = await client.auth.updateUser({ password: password });
          if (updateResult.error) { showClientError(updateResult.error.message); btn.disabled = false; btn.textContent = MSG_RESET; return; }

          window.location.href = '/login?passwordChanged=1';
        } catch (err) {
          showClientError(MSG_ERROR);
          btn.disabled = false;
          btn.textContent = MSG_RESET;
        }
      });

    } else {
      document.getElementById('detecting-state').classList.add('hidden');
      document.getElementById('invalid-state').classList.remove('hidden');
      showClientError(MSG_INVALID);
    }
  })();
  </script>
  <% } %>

</body>
</html>
