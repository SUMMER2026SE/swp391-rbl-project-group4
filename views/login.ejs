<%- include('partials/head') %>
<body class="font-body-md text-on-surface min-h-screen flex flex-col items-center justify-center p-gutter"
      style="-webkit-font-smoothing: antialiased;">

  <!-- Background -->
  <div class="japanese-bg" style="background-image: url('https://lh3.googleusercontent.com/aida-public/AB6AXuCfZQt6pWUjeOqUvJ73OGEteZmuBNxFnHmlDjwGUXdajYNUwqGhkC588yCsMd8jZ81ER_hWwY_1npRt9E7Ame0OuGgy1RCcNH65XlCaYShMm5LESCT-7fbNT1Z8m3lozcjR4NxGN4bYhnL5ZJ4b2n9jb7GMrzzBU-JuAdPcz7LWwywzHROcyKHHHLBFNZntG13s98pwWuBO8Lo3qahrbEf-fzu8Qd1-_pFKTuwto22xgR8VGWdICAW7yq9vI2uDkZvOwPE5OprNUzS9')"></div>

  <main class="w-full max-w-[440px] animate-fade-in">

    <!-- Branding -->
    <div class="text-center mb-xl">
      <a href="/" class="font-display text-display-mobile md:text-display font-bold text-tsubaki-red tracking-tight mb-xs block">
        Kizuna Nihongo
      </a>
      <p class="font-body-md text-on-surface-variant ma-spacing"><%= t('common.tagline') %></p>
    </div>

    <!-- Login Card -->
    <div class="glass-card rounded-xl p-md md:p-lg space-y-md">

      <div class="space-y-xs pb-sm">
        <h2 class="font-h2 text-h2 text-on-surface"><%= t('auth.login_heading') %></h2>
        <p class="font-caption text-on-surface-variant"><%= t('auth.login_sub') %></p>
      </div>

      <% if (success) { %>
      <div class="flex items-center gap-base px-md py-sm rounded-lg bg-green-50 text-green-800 border border-green-200 font-caption">
        <span class="material-symbols-outlined text-[16px]">check_circle</span>
        <%= success %>
      </div>
      <% } %>
      <% if (error) { %>
      <div class="flex items-center gap-base px-md py-sm rounded-lg bg-error-container text-on-error-container font-caption">
        <span class="material-symbols-outlined text-[16px]">error</span>
        <%= error %>
      </div>
      <% } %>

      <form action="/login" method="POST" class="space-y-md">

        <!-- Email -->
        <div class="space-y-xs">
          <label class="font-label-md text-label-md text-on-surface-variant block" for="email"><%= t('auth.email') %></label>
          <input
            id="email" name="email" type="email"
            placeholder="your@email.com" required autocomplete="email"
            class="w-full bg-transparent border-b border-outline-variant focus:border-tsubaki-red focus:ring-0 transition-all duration-300 py-base px-0 font-body-md outline-none">
        </div>

        <!-- Password -->
        <div class="space-y-xs">
          <div class="flex justify-between items-center">
            <label class="font-label-md text-label-md text-on-surface-variant" for="password"><%= t('auth.password') %></label>
            <a href="/forgot-password" class="font-caption text-tsubaki-red hover:underline transition-all"><%= t('auth.forgot_password') %></a>
          </div>
          <div class="relative">
            <input
              id="password" name="password" type="password"
              placeholder="••••••••" required autocomplete="current-password"
              class="w-full bg-transparent border-b border-outline-variant focus:border-tsubaki-red focus:ring-0 transition-all duration-300 py-base px-0 font-body-md outline-none pr-8">
            <button id="toggle-password" type="button"
              class="absolute right-0 bottom-base text-on-surface-variant hover:text-tsubaki-red transition-colors"
              aria-label="<%= t('auth.show_hide_password') %>">
              <span id="toggle-password-icon" class="material-symbols-outlined text-[20px]">visibility</span>
            </button>
          </div>
        </div>

        <!-- Submit -->
        <div class="pt-sm">
          <button type="submit"
            class="w-full bg-tsubaki-red text-on-primary font-label-md text-label-md py-md rounded-lg shadow-sm hover:bg-primary transition-all duration-300 active:scale-[0.98] focus:outline-none focus:ring-2 focus:ring-tsubaki-red focus:ring-offset-2">
            <%= t('auth.submit_login') %>
          </button>
        </div>
      </form>

      <!-- Divider -->
      <div class="relative py-base">
        <div class="absolute inset-0 flex items-center">
          <span class="w-full border-t border-outline-variant/30"></span>
        </div>
        <div class="relative flex justify-center">
          <span class="bg-white/70 px-sm font-caption text-on-surface-variant"><%= t('auth.or_use') %></span>
        </div>
      </div>

      <!-- Social login -->
      <div class="grid grid-cols-2 gap-sm">
        <button type="button"
          class="flex items-center justify-center gap-xs border border-outline-variant rounded-lg py-sm font-label-md text-label-md text-charcoal-text hover:bg-white transition-all duration-200">
          <span class="material-symbols-outlined text-[18px]">account_circle</span>
          Google
        </button>
        <button type="button"
          class="flex items-center justify-center gap-xs border border-outline-variant rounded-lg py-sm font-label-md text-label-md text-charcoal-text hover:bg-white transition-all duration-200">
          <span class="material-symbols-outlined text-[18px]">ios</span>
          Apple
        </button>
      </div>

    </div>

    <!-- Register link -->
    <div class="mt-md text-center">
      <p class="font-body-md text-on-surface-variant">
        <%= t('auth.no_account') %>
        <a href="/register" class="text-tsubaki-red font-semibold hover:underline ml-xs transition-all"><%= t('auth.register_new') %></a>
      </p>
    </div>

  </main>

  <!-- Zen ornament -->
  <div class="mt-xl opacity-20 pointer-events-none select-none">
    <svg width="40" height="40" viewBox="0 0 40 40" fill="none" xmlns="http://www.w3.org/2000/svg" class="text-tsubaki-red animate-pulse">
      <circle cx="20" cy="20" r="18" stroke="currentColor" stroke-width="0.5" stroke-dasharray="2 4"/>
      <circle cx="20" cy="20" r="12" stroke="currentColor" stroke-width="1"/>
      <circle cx="20" cy="20" r="2" fill="currentColor"/>
    </svg>
  </div>

  <!-- Copyright -->
  <footer class="fixed bottom-gutter w-full text-center pointer-events-none">
    <p class="font-caption text-on-surface-variant opacity-60">
      <%= t('common.copyright') %>
    </p>
  </footer>

  <script src="/js/login.js"></script>
</body>
</html>
