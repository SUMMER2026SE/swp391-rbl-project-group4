<%- include('partials/head') %>
<body class="font-body-md text-on-surface min-h-screen flex flex-col items-center justify-center p-gutter"
      style="-webkit-font-smoothing: antialiased; background-color: #f7f7f5;">

  <!-- Atmospheric blobs -->
  <div class="fixed inset-0 pointer-events-none overflow-hidden -z-10">
    <div class="absolute -top-24 -right-24 w-96 h-96 rounded-full blur-3xl" style="background:rgba(113,42,226,0.05)"></div>
    <div class="absolute -bottom-24 -left-24 w-80 h-80 rounded-full blur-3xl" style="background:rgba(174,40,38,0.05)"></div>
    <div class="absolute inset-0" style="background:radial-gradient(circle at 50% 50%,rgba(174,40,38,0.04) 0%,transparent 70%)"></div>
  </div>

  <main class="w-full max-w-[440px] animate-fade-in">

    <!-- Branding -->
    <div class="text-center mb-xl">
      <a href="/" class="font-display text-display-mobile md:text-display font-bold text-tsubaki-red tracking-tight mb-xs block">
        Kizuna Nihongo
      </a>
      <p class="font-body-md text-on-surface-variant ma-spacing"><%= t('common.tagline') %></p>
    </div>

    <!-- Card -->
    <div class="glass-card rounded-xl p-md md:p-lg space-y-md">

      <div class="flex flex-col items-center text-center space-y-sm pb-sm">
        <span class="material-symbols-outlined text-tsubaki-red" style="font-size:48px">lock_reset</span>
        <h2 class="font-h2 text-h2 text-on-surface"><%= t('auth.forgot_heading') %></h2>
        <p class="font-caption text-on-surface-variant"><%= t('auth.forgot_sub') %></p>
      </div>

      <% if (success) { %>
      <div class="flex items-start gap-base px-md py-sm rounded-lg bg-green-50 text-green-800 border border-green-200 font-caption">
        <span class="material-symbols-outlined text-[16px] mt-0.5" style="font-variation-settings:'FILL' 1">check_circle</span>
        <span><%= success %></span>
      </div>
      <% } %>

      <% if (error) { %>
      <div class="flex items-center gap-base px-md py-sm rounded-lg bg-error-container text-on-error-container font-caption">
        <span class="material-symbols-outlined text-[16px]">error</span>
        <%= error %>
      </div>
      <% } %>

      <% if (!success) { %>
      <form action="/forgot-password" method="POST" class="space-y-md">
        <div class="space-y-xs">
          <label class="font-label-md text-label-md text-on-surface-variant block" for="email"><%= t('auth.forgot_email_label') %></label>
          <input
            id="email" name="email" type="email"
            placeholder="email@example.com" required autocomplete="email"
            class="w-full bg-transparent border-b border-outline-variant focus:border-tsubaki-red focus:ring-0 transition-all duration-300 py-base px-0 font-body-md outline-none">
        </div>
        <div class="pt-sm">
          <button type="submit"
            class="w-full bg-tsubaki-red text-on-primary font-label-md text-label-md py-md rounded-lg shadow-sm hover:bg-primary transition-all duration-300 active:scale-[0.98] focus:outline-none focus:ring-2 focus:ring-tsubaki-red focus:ring-offset-2">
            <%= t('auth.forgot_submit') %>
          </button>
        </div>
      </form>
      <% } %>

      <div class="text-center pt-sm">
        <a href="/login" class="inline-flex items-center gap-xs font-label-md text-label-md text-on-surface-variant hover:text-tsubaki-red transition-colors duration-300">
          <span class="material-symbols-outlined text-[18px]">arrow_back</span>
          <%= t('auth.back_to_login') %>
        </a>
      </div>

    </div>
  </main>

  <footer class="fixed bottom-gutter w-full text-center pointer-events-none">
    <p class="font-caption text-on-surface-variant opacity-60">
      <%= t('common.copyright') %>
    </p>
  </footer>

</body>
</html>
