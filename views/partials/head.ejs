            xl: "80px", xs: "4px", "max-width-desktop": "1200px",
            base: "8px", gutter: "24px", sm: "12px",
            "margin-mobile": "16px", md: "24px", lg: "48px",
          },
          fontFamily: {
            h2: ["Plus Jakarta Sans"], display: ["Plus Jakarta Sans"],
            "body-md": ["Inter"], "body-lg": ["Inter"],
