<!DOCTYPE html>
<html class="light" lang="<%= lang || 'vi' %>">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %></title>
  <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
  <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&family=Inter:wght@300;400;500;600&family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet">
  <script>
    tailwind.config = {
      darkMode: "class",
      theme: {
        extend: {
          colors: {
            "on-surface": "#121c2a",
            "outline": "#8d706d",
            "primary-container": "#ae2826",
            "surface-container-high": "#dfe9fc",
            "surface-container-highest": "#d9e3f7",
            "primary": "#8c0b12",
            "tsubaki-red": "#ae2826",
            "on-primary": "#ffffff",
            "surface": "#f8f9ff",
            "primary-fixed": "#ffdad6",
            "surface-container-lowest": "#ffffff",
            "charcoal-text": "#1f2937",
            "surface-bright": "#f8f9ff",
            "secondary": "#712ae2",
            "on-background": "#121c2a",
            "tertiary-container": "#5b5c5b",
            "inverse-surface": "#273140",
            "surface-container": "#e6eeff",
            "inverse-on-surface": "#ebf1ff",
            "on-secondary": "#ffffff",
            "secondary-container": "#8b4bfc",
            "sumire-purple": "#712ae2",
            "on-secondary-container": "#fffbff",
            "on-surface-variant": "#59413e",
            "on-primary-container": "#ffc8c2",
            "inverse-primary": "#ffb4ac",
            "primary-fixed-dim": "#ffb4ac",
            "surface-stone": "#f7f7f5",
            "on-tertiary": "#ffffff",
            "surface-variant": "#d9e3f7",
            "surface-container-low": "#eff3ff",
            "surface-tint": "#b12b28",
            "error": "#ba1a1a",
            "on-error": "#ffffff",
