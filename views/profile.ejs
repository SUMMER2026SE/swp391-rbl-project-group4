<!DOCTYPE html>
<html lang="<%= lang %>">
<head>
  <meta charset="utf-8"/>
  <meta content="width=device-width, initial-scale=1.0" name="viewport"/>
  <title><%= title %></title>
  <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&family=Plus+Jakarta+Sans:wght@600;700;800&display=swap" rel="stylesheet"/>
  <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet"/>
  <script>
    tailwind.config = {
      darkMode: "class",
      theme: {
        extend: {
          colors: {
            "tsubaki-red": "#ae2826", "primary": "#8c0b12", "on-primary": "#ffffff",
            "sumire-purple": "#712ae2", "secondary": "#712ae2", "secondary-container": "#8b4bfc",
            "on-surface": "#121c2a", "on-surface-variant": "#59413e", "on-background": "#121c2a",
            "surface": "#f8f9ff", "surface-bright": "#f8f9ff", "surface-stone": "#f7f7f5",
            "surface-container": "#e6eeff", "surface-container-low": "#eff3ff",
            "surface-container-high": "#dfe9fc", "surface-container-highest": "#d9e3f7",
            "surface-container-lowest": "#ffffff", "surface-variant": "#d9e3f7",
            "outline": "#8d706d", "outline-variant": "#e1bfbb",
            "primary-container": "#ae2826", "on-primary-container": "#ffc8c2",
            "error": "#ba1a1a", "error-container": "#ffdad6", "on-error-container": "#93000a",
            "inverse-surface": "#273140", "inverse-on-surface": "#ebf1ff",
            "tertiary-container": "#5b5c5b", "on-tertiary": "#ffffff",
          },
          borderRadius: { DEFAULT: "0.5rem", lg: "0.75rem", xl: "1rem", "2xl": "1.5rem", "3xl": "1.75rem", full: "9999px" },
          spacing: { sm: "12px", base: "16px", md: "32px", lg: "64px", xl: "96px", gutter: "32px" }
        }
      }
    }
  </script>
  <style>
    .material-symbols-outlined { font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24; }
    .material-symbols-outlined.fill { font-variation-settings: 'FILL' 1, 'wght' 400, 'GRAD' 0, 'opsz' 24; }
    body { font-family: 'Inter', sans-serif; background-color: #f7f7f5; color: #121c2a; }
    h1, h2, h3, h4 { font-family: 'Plus Jakarta Sans', sans-serif; }
    .glass-card { background: rgba(255,255,255,0.7); backdrop-filter: blur(12px); border: 1px solid rgba(229,231,235,0.5); box-shadow: 0 4px 20px rgba(0,0,0,0.04); }
    .zen-shadow { box-shadow: 0 4px 30px rgba(0,0,0,0.03); }
    .input-zen { border: none; border-bottom: 2px solid #e5e7eb; transition: all 0.3s ease; background: transparent; width: 100%; padding: 6px 0; }
    .input-zen:focus { border-bottom-color: #ae2826; outline: none; }
  </style>
</head>
<body class="flex min-h-screen">

<!-- ── Sidebar ───────────────────────────────────────────────────────────────── -->
<aside class="hidden md:flex flex-col p-md h-screen w-72 bg-surface-container-lowest border-r border-outline-variant fixed left-0 top-0 z-40">
  <div class="mb-xl px-2">
    <a href="/" class="text-3xl font-extrabold text-tsubaki-red tracking-tight block">Kizuna Nihongo</a>
    <p class="text-sm font-medium text-on-surface-variant opacity-70 mt-1 uppercase tracking-widest"><%= t('profile.student_label') %></p>
  </div>
  <nav class="flex-1 flex flex-col gap-4">
    <a href="/dashboard" class="text-on-surface-variant hover:text-primary hover:bg-surface-container-low transition-all rounded-xl p-4 flex items-center gap-4 group">
      <span class="material-symbols-outlined group-hover:scale-110 transition-transform">dashboard</span>
      <span class="text-md font-medium"><%= t('profile.nav_dashboard') %></span>
    </a>
    <a href="#" class="text-on-surface-variant hover:text-primary hover:bg-surface-container-low transition-all rounded-xl p-4 flex items-center gap-4 group">
      <span class="material-symbols-outlined group-hover:scale-110 transition-transform">menu_book</span>
      <span class="text-md font-medium"><%= t('profile.nav_study') %></span>
    </a>
    <a href="#" class="text-on-surface-variant hover:text-primary hover:bg-surface-container-low transition-all rounded-xl p-4 flex items-center gap-4 group">
      <span class="material-symbols-outlined group-hover:scale-110 transition-transform">groups</span>
      <span class="text-md font-medium"><%= t('profile.nav_class') %></span>
    </a>
    <a href="#" class="text-on-surface-variant hover:text-sumire-purple hover:bg-surface-container-low transition-all rounded-xl p-4 flex items-center gap-4 group">
      <span class="material-symbols-outlined group-hover:scale-110 transition-transform text-sumire-purple">auto_awesome</span>
      <span class="text-md font-medium"><%= t('profile.nav_ai') %></span>
    </a>
    <a href="/profile" class="bg-surface-container-high text-tsubaki-red border-l-4 border-tsubaki-red rounded-xl p-4 flex items-center gap-4 font-semibold">
      <span class="material-symbols-outlined fill">person</span>
      <span class="text-md"><%= t('profile.nav_profile') %></span>
    </a>
  </nav>
  <div class="mt-auto pt-md border-t border-outline-variant/30">
    <a href="/logout" class="w-full py-4 px-6 bg-surface-container-high text-on-surface font-bold rounded-xl hover:bg-outline-variant transition-colors flex items-center justify-center gap-2">
      <span class="material-symbols-outlined text-xl">logout</span>
      <%= t('nav.logout') %>
    </a>
  </div>
</aside>

<!-- ── Content wrapper ────────────────────────────────────────────────────────── -->
<div class="flex-1 md:ml-72 flex flex-col min-h-screen">

  <!-- ── Top bar ────────────────────────────────────────────────────────────── -->
  <header class="bg-surface/80 backdrop-blur-md border-b border-outline-variant/30 flex justify-between items-center h-20 px-md md:px-lg w-full sticky top-0 z-50">
    <div class="flex items-center gap-2">
      <span class="w-2 h-2 rounded-full bg-tsubaki-red hidden md:block"></span>
      <span class="text-sm font-semibold text-on-surface-variant tracking-widest uppercase opacity-60 hidden md:block"><%= t('profile.page_header') %></span>
      <span class="md:hidden text-2xl font-extrabold text-tsubaki-red">Kizuna Nihongo</span>
    </div>
    <div class="relative" id="avatar-menu">
      <button id="avatar-btn" class="w-11 h-11 rounded-full overflow-hidden border-2 border-tsubaki-red/20 hover:border-tsubaki-red transition-colors cursor-pointer bg-primary flex items-center justify-center focus:outline-none">
        <% if (user.avatar_url) { %>
          <img alt="<%= user.fullname %>" class="w-full h-full object-cover" src="<%= user.avatar_url %>"/>
        <% } else { %>
          <span class="text-white font-bold text-lg select-none"><%= user.fullname.charAt(0).toUpperCase() %></span>
        <% } %>
      </button>
      <div id="avatar-dropdown" class="hidden absolute right-0 mt-2 w-52 bg-white rounded-2xl shadow-xl border border-outline-variant/30 z-50 overflow-hidden">
        <div class="px-4 py-3 border-b border-outline-variant/20">
          <p class="text-sm font-bold text-on-surface truncate"><%= user.fullname %></p>
          <p class="text-xs text-on-surface-variant truncate"><%= user.email %></p>
        </div>
        <a href="/dashboard" class="flex items-center gap-3 px-4 py-3 text-sm font-medium text-on-surface hover:bg-surface-container-low transition-colors">
          <span class="material-symbols-outlined text-[18px]">dashboard</span>
          <%= t('profile.nav_dashboard') %>
        </a>
        <div class="border-t border-outline-variant/20"></div>
        <a href="/logout" class="flex items-center gap-3 px-4 py-3 text-sm font-medium text-error hover:bg-error-container/30 transition-colors">
          <span class="material-symbols-outlined text-[18px]">logout</span>
          <%= t('nav.logout') %>
        </a>
      </div>
    </div>
  </header>

  <!-- ── Main ───────────────────────────────────────────────────────────────── -->
  <main class="p-md md:p-lg max-w-[1200px] mx-auto w-full pb-24 md:pb-lg">

    <!-- Alerts -->
    <% if (saved) { %>
    <div class="mb-md flex items-center gap-3 px-md py-sm rounded-2xl bg-green-50 text-green-800 border border-green-200">
      <span class="material-symbols-outlined fill text-green-600">check_circle</span>
      <span class="font-semibold"><%= t('success.profile_saved') %></span>
    </div>
    <% } %>
    <% if (locals.avatarSaved) { %>
    <div class="mb-md flex items-center gap-3 px-md py-sm rounded-2xl bg-green-50 text-green-800 border border-green-200">
      <span class="material-symbols-outlined fill text-green-600">check_circle</span>
      <span class="font-semibold"><%= t('success.avatar_saved') %></span>
    </div>
    <% } %>
    <% if (locals.avatarError) { %>
    <div class="mb-md flex items-center gap-3 px-md py-sm rounded-2xl bg-error-container text-on-error-container border border-error/20">
      <span class="material-symbols-outlined">error</span>
      <span class="font-semibold"><%= t('profile.avatar_error') %></span>
    </div>
    <% } %>
    <% if (locals.emailSent) { %>
    <div class="mb-md flex items-center gap-3 px-md py-sm rounded-2xl bg-blue-50 text-blue-800 border border-blue-200">
      <span class="material-symbols-outlined fill text-blue-600">mark_email_read</span>
      <span class="font-semibold"><%= t('success.email_sent') %></span>
    </div>
    <% } %>
    <% if (error) { %>
    <div class="mb-md flex items-center gap-3 px-md py-sm rounded-2xl bg-error-container text-on-error-container border border-error/20">
      <span class="material-symbols-outlined">error</span>
      <span class="font-semibold"><%= error %></span>
    </div>
    <% } %>

    <!-- Profile hero -->
    <section class="mb-lg">
      <div class="flex flex-col md:flex-row items-center gap-md">

        <!-- Avatar with upload -->
        <div class="relative shrink-0 group">
          <form action="/profile/avatar" method="POST" enctype="multipart/form-data" id="avatar-form">
            <input type="file" id="avatar-input" name="avatar" accept="image/*" class="hidden"/>
            <button type="button" id="avatar-trigger"
              class="block w-32 h-32 md:w-36 md:h-36 rounded-full border-4 border-white shadow-xl overflow-hidden bg-primary focus:outline-none cursor-pointer relative">
              <% if (userData.avatar_url) { %>
                <img id="avatar-preview" alt="<%= user.fullname %>" class="w-full h-full object-cover" src="<%= userData.avatar_url %>"/>
              <% } else { %>
                <img id="avatar-preview" class="w-full h-full object-cover hidden"/>
                <span id="avatar-initial" class="text-white font-bold select-none" style="font-size:3rem"><%= user.fullname.charAt(0).toUpperCase() %></span>
              <% } %>
              <!-- Hover overlay -->
              <div class="absolute inset-0 bg-black/40 rounded-full flex items-center justify-center opacity-0 group-hover:opacity-100 transition-opacity">
                <span class="material-symbols-outlined text-white" style="font-size:28px">photo_camera</span>
              </div>
            </button>
          </form>
          <div id="avatar-save-bar" class="hidden absolute -bottom-10 left-1/2 -translate-x-1/2 whitespace-nowrap">
            <button form="avatar-form" type="submit"
              class="bg-tsubaki-red text-white text-xs font-bold px-4 py-1.5 rounded-full shadow-lg hover:bg-primary transition-colors">
              <%= t('profile.save_avatar') %>
            </button>
          </div>
        </div>

        <div class="text-center md:text-left mt-10 md:mt-0">
          <h2 class="text-4xl md:text-5xl font-extrabold text-on-surface tracking-tight"><%= userData.full_name || user.fullname %></h2>
          <div class="flex items-center justify-center md:justify-start gap-2 mt-2">
            <span class="material-symbols-outlined text-tsubaki-red fill text-[18px]">stars</span>
            <span class="text-sm font-bold text-tsubaki-red uppercase tracking-widest"><%= t('profile.student_label') %></span>
          </div>
          <p class="text-sm text-on-surface-variant mt-1"><%= user.email %></p>
        </div>
      </div>
    </section>

    <!-- Grid -->
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-gutter">

      <!-- ── Left column ─────────────────────────────────────────────────── -->
      <div class="lg:col-span-2 space-y-gutter">

        <!-- Personal info form -->
        <section class="glass-card rounded-2xl p-md zen-shadow">
          <h3 class="text-xl font-bold text-on-surface mb-md border-l-4 border-tsubaki-red pl-4"><%= t('profile.personal_info') %></h3>
          <form action="/profile" method="POST" id="profile-form" class="space-y-md">
            <div class="grid grid-cols-1 md:grid-cols-2 gap-md">

              <div class="space-y-1">
                <label class="text-sm font-medium text-on-surface-variant block"><%= t('profile.fullname_label') %></label>
                <input name="fullname" type="text" class="input-zen" required
                  value="<%= userData.full_name || user.fullname %>"/>
              </div>

              <div class="space-y-1">
                <label class="text-sm font-medium text-on-surface-variant block"><%= t('profile.email_label') %></label>
                <div class="flex items-center gap-2 bg-surface-container-low px-3 py-2 rounded-xl border border-outline-variant/30">
                  <span class="text-sm text-on-surface-variant flex-1 truncate"><%= userData.email || user.email %></span>
                  <% if (userData.is_email_verified) { %>
                  <span class="material-symbols-outlined fill text-sumire-purple text-[16px]">verified</span>
                  <% } %>
                </div>
              </div>

              <div class="space-y-1">
                <label class="text-sm font-medium text-on-surface-variant block"><%= t('profile.phone_label') %></label>
                <input name="phone" type="tel" class="input-zen" placeholder="09x xxx xxxx"
                  value="<%= userData.phone || '' %>"/>
              </div>

              <div class="space-y-1">
                <label class="text-sm font-medium text-on-surface-variant block"><%= t('profile.jlpt_goal_label') %></label>
                <select name="jlptTarget" class="input-zen">
                  <option value=""><%= t('profile.jlpt_not_selected') %></option>
                  <% const levels = ['N5','N4','N3','N2','N1'];
                     const currentTarget = (profileData.jlpt_target_level || '').trim();
                     levels.forEach(lv => { %>
                  <option value="<%= lv %>" <%= currentTarget === lv ? 'selected' : '' %>><%= lv %></option>
                  <% }); %>
                </select>
              </div>

            </div>

            <div class="space-y-1">
              <label class="text-sm font-medium text-on-surface-variant block"><%= t('profile.bio_label') %></label>
              <textarea name="bio" rows="3"
                class="w-full bg-transparent border border-outline-variant rounded-xl focus:border-tsubaki-red focus:ring-0 px-3 py-3 text-sm transition-colors resize-none"
                placeholder="<%= t('profile.bio_placeholder') %>"><%= profileData.study_goal || '' %></textarea>
            </div>

            <!-- Action buttons inside form -->
            <div class="flex gap-3 pt-sm">
              <button type="submit"
                class="flex-1 bg-tsubaki-red text-white py-3 rounded-xl font-bold shadow-lg shadow-tsubaki-red/20 hover:bg-primary active:scale-95 transition-all">
                <%= t('profile.save') %>
              </button>
              <a href="/profile"
                class="flex-1 text-center bg-surface-container-high text-on-surface-variant py-3 rounded-xl font-bold hover:bg-outline-variant/50 transition-all">
                <%= t('profile.cancel') %>
              </a>
            </div>
          </form>
        </section>

        <!-- Stats row -->
        <section class="grid grid-cols-3 gap-md">
          <div class="glass-card rounded-2xl p-md flex flex-col items-center text-center zen-shadow">
            <span class="material-symbols-outlined text-tsubaki-red mb-2" style="font-size:32px">schedule</span>
            <p class="text-xs font-bold text-on-surface-variant uppercase tracking-wider mb-1"><%= t('profile.total_hours_label') %></p>
            <p class="text-3xl font-extrabold text-on-surface">
              <%= Math.round((dashData.total_study_minutes || 0) / 60) %>
              <span class="text-base font-normal ml-1"><%= t('common.hours') %></span>
            </p>
          </div>
          <div class="glass-card rounded-2xl p-md flex flex-col items-center text-center border-b-4 border-sumire-purple zen-shadow">
            <span class="material-symbols-outlined text-sumire-purple mb-2" style="font-size:32px">local_fire_department</span>
            <p class="text-xs font-bold text-on-surface-variant uppercase tracking-wider mb-1"><%= t('profile.streak_label') %></p>
            <p class="text-3xl font-extrabold text-on-surface">
              <%= dashData.current_streak || profileData.streak_days || 0 %>
              <span class="text-base font-normal ml-1"><%= t('common.days') %></span>
            </p>
          </div>
          <div class="glass-card rounded-2xl p-md flex flex-col items-center text-center zen-shadow">
            <span class="material-symbols-outlined text-tsubaki-red mb-2" style="font-size:32px">ads_click</span>
            <p class="text-xs font-bold text-on-surface-variant uppercase tracking-wider mb-1"><%= t('profile.jlpt_target_label') %></p>
            <p class="text-3xl font-extrabold text-on-surface">
              <%= (profileData.jlpt_target_level || '').trim() || '—' %>
            </p>
          </div>
        </section>

      </div>

      <!-- ── Right column ────────────────────────────────────────────────── -->
      <div class="space-y-gutter">

        <!-- Account settings -->
        <section class="glass-card rounded-2xl p-md zen-shadow" style="border-left: 3px solid rgba(113,42,226,0.3)">
          <div class="flex items-center gap-2 mb-md">
            <span class="material-symbols-outlined text-sumire-purple">tune</span>
            <h3 class="text-xl font-bold text-on-surface"><%= t('profile.account_settings') %></h3>
          </div>
          <div class="space-y-md">
            <div class="space-y-2">
              <label class="text-sm font-medium text-on-surface-variant block"><%= t('profile.display_lang') %></label>
              <div class="flex gap-2">
                <form action="/lang" method="POST" style="flex:1">
                  <input type="hidden" name="lang" value="vi"/>
                  <button type="submit" class="w-full py-2 rounded-xl border text-sm font-semibold transition-colors
                    <%= lang === 'vi' ? 'border-tsubaki-red text-tsubaki-red' : 'border-outline-variant text-on-surface-variant hover:bg-surface-container' %>">
                    Tiếng Việt
                  </button>
                </form>
                <form action="/lang" method="POST" style="flex:1">
                  <input type="hidden" name="lang" value="ja"/>
                  <button type="submit" class="w-full py-2 rounded-xl border text-sm font-semibold transition-colors
                    <%= lang === 'ja' ? 'border-tsubaki-red text-tsubaki-red' : 'border-outline-variant text-on-surface-variant hover:bg-surface-container' %>">
                    日本語
                  </button>
                </form>
              </div>
            </div>
            <div class="pt-sm space-y-4">
              <div class="flex items-center justify-between">
                <span class="text-sm font-medium text-on-surface"><%= t('profile.lesson_notif') %></span>
                <label class="relative inline-flex items-center cursor-pointer">
                  <input type="checkbox" class="sr-only peer" checked/>
                  <div class="w-11 h-6 bg-surface-container-highest rounded-full peer peer-checked:after:translate-x-full peer-checked:after:border-white after:content-[''] after:absolute after:top-[2px] after:start-[2px] after:bg-white after:border after:rounded-full after:h-5 after:w-5 after:transition-all peer-checked:bg-tsubaki-red"></div>
                </label>
              </div>
              <div class="flex items-center justify-between">
                <span class="text-sm font-medium text-on-surface"><%= t('profile.ai_reminder') %></span>
                <label class="relative inline-flex items-center cursor-pointer">
                  <input type="checkbox" class="sr-only peer" checked/>
                  <div class="w-11 h-6 bg-surface-container-highest rounded-full peer peer-checked:after:translate-x-full peer-checked:after:border-white after:content-[''] after:absolute after:top-[2px] after:start-[2px] after:bg-white after:border after:rounded-full after:h-5 after:w-5 after:transition-all peer-checked:bg-sumire-purple"></div>
                </label>
              </div>
            </div>
          </div>
        </section>

        <!-- AI tip -->
        <div class="glass-card rounded-2xl p-md border-l-4 border-sumire-purple zen-shadow" style="background: linear-gradient(135deg, rgba(255,255,255,0.9), rgba(239,243,255,0.8))">
          <div class="flex items-center gap-2 text-sumire-purple mb-2">
            <span class="material-symbols-outlined fill">auto_awesome</span>
            <p class="text-sm font-bold"><%= t('profile.ai_tip_title') %></p>
          </div>
          <p class="text-sm text-on-surface-variant italic leading-relaxed">
            <% if ((dashData.current_streak || 0) >= 7) { %>
              "<%= t('profile.ai_tip_7plus', { n: dashData.current_streak }) %>"
            <% } else if ((dashData.current_streak || 0) > 0) { %>
              "<%= t('profile.ai_tip_active') %>"
            <% } else { %>
              "<%= t('profile.ai_tip_none') %>"
            <% } %>
          </p>
        </div>

        <!-- Change password -->
        <section class="glass-card rounded-2xl p-md zen-shadow">
          <div class="flex items-center gap-2 mb-3">
            <span class="material-symbols-outlined text-tsubaki-red">lock_reset</span>
            <h3 class="text-lg font-bold text-on-surface"><%= t('profile.change_password') %></h3>
          </div>
          <p class="text-sm text-on-surface-variant mb-4 leading-relaxed">
            <%= t('profile.change_password_desc', { email: user.email }) %>
          </p>
          <form action="/profile/change-password" method="POST">
            <button type="submit"
              class="w-full flex items-center justify-center gap-2 bg-surface-container-high text-on-surface font-bold py-3 rounded-xl hover:bg-outline-variant/50 active:scale-95 transition-all border border-outline-variant/30">
              <span class="material-symbols-outlined text-[18px]">mail</span>
              <%= t('profile.send_password_email') %>
            </button>
          </form>
        </section>

        <!-- Current level info -->
        <% if ((profileData.current_level || '').trim()) { %>
        <div class="glass-card rounded-2xl p-md zen-shadow text-center">
          <p class="text-xs font-bold text-on-surface-variant uppercase tracking-widest mb-2"><%= t('profile.current_level') %></p>
          <p class="text-5xl font-extrabold text-tsubaki-red"><%= profileData.current_level.trim() %></p>
          <p class="text-sm text-on-surface-variant mt-2"><%= t('profile.assessed_by') %></p>
        </div>
        <% } %>

      </div>
    </div>
  </main>
</div>

<!-- ── Mobile bottom nav ──────────────────────────────────────────────────── -->
<nav class="md:hidden bg-white/90 backdrop-blur-lg border-t border-outline-variant/30 fixed bottom-0 left-0 right-0 h-20 flex justify-around items-center z-50 px-4">
  <a href="/dashboard" class="flex flex-col items-center gap-1 text-on-surface-variant opacity-60">
    <span class="material-symbols-outlined">dashboard</span>
    <span class="text-[10px] font-bold">Home</span>
  </a>
  <a href="#" class="flex flex-col items-center gap-1 text-on-surface-variant opacity-60">
    <span class="material-symbols-outlined">menu_book</span>
    <span class="text-[10px] font-bold">Study</span>
  </a>
  <a href="#" class="flex flex-col items-center gap-1 text-on-surface-variant opacity-60">
