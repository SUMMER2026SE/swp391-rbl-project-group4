<%- include('partials/head') %>
<body class="bg-surface-stone min-h-screen flex items-center justify-center ma-bg p-margin-mobile md:p-gutter">

  <!-- Background blobs -->
  <div class="fixed inset-0 pointer-events-none overflow-hidden">
    <div class="absolute -top-24 -right-24 w-96 h-96 bg-tsubaki-red/5 rounded-full blur-3xl"></div>
    <div class="absolute -bottom-24 -left-24 w-80 h-80 bg-sumire-purple/5 rounded-full blur-3xl"></div>
  </div>

  <main class="relative z-10 w-full max-w-[480px]">
    <div class="glass-card rounded-xl p-lg md:p-xl flex flex-col items-center">

      <!-- Brand -->
      <div class="mb-lg text-center">
        <a href="/" class="font-display text-display-mobile md:text-display text-tsubaki-red tracking-tight mb-xs block">
          Kizuna Nihongo
        </a>
        <p class="font-label-md text-label-md text-on-surface-variant/70 uppercase tracking-widest"><%= t('common.art_of_mastery') %></p>
      </div>

      <!-- Heading -->
      <div class="text-center mb-lg">
        <h2 class="font-h1 text-h1-mobile md:text-h1 text-charcoal-text mb-sm"><%= t('auth.register_heading') %></h2>
        <p class="font-body-md text-body-md text-on-surface-variant"><%= t('auth.register_sub') %></p>
      </div>

      <!-- Error banner -->
      <% if (error) { %>
      <div class="w-full flex items-center gap-base px-md py-sm rounded-lg bg-error-container text-on-error-container font-caption mb-md">
        <span class="material-symbols-outlined text-[16px]">error</span>
        <%= error %>
      </div>
      <% } %>

      <!-- Form -->
      <form action="/register" method="POST" class="w-full space-y-md">

        <!-- Full name -->
        <div class="space-y-xs">
          <label class="font-label-md text-label-md text-on-surface-variant block ml-xs" for="fullname"><%= t('auth.fullname') %></label>
          <div class="relative group">
            <span class="material-symbols-outlined absolute left-base top-1/2 -translate-y-1/2 text-on-surface-variant group-focus-within:text-tsubaki-red transition-colors">person</span>
            <input id="fullname" name="fullname" type="text"
              placeholder="<%= t('auth.fullname_placeholder') %>" required autocomplete="name"
              class="w-full pl-lg pr-md py-base bg-surface-container-lowest border-0 border-b-2 border-outline-variant/30 focus:border-tsubaki-red focus:ring-0 rounded-lg transition-all font-body-md text-body-md text-charcoal-text outline-none">
          </div>
        </div>

        <!-- Email -->
        <div class="space-y-xs">
          <label class="font-label-md text-label-md text-on-surface-variant block ml-xs" for="email"><%= t('auth.email') %></label>
          <div class="relative group">
            <span class="material-symbols-outlined absolute left-base top-1/2 -translate-y-1/2 text-on-surface-variant group-focus-within:text-tsubaki-red transition-colors">mail</span>
            <input id="email" name="email" type="email"
              placeholder="email@example.com" required autocomplete="email"
              class="w-full pl-lg pr-md py-base bg-surface-container-lowest border-0 border-b-2 border-outline-variant/30 focus:border-tsubaki-red focus:ring-0 rounded-lg transition-all font-body-md text-body-md text-charcoal-text outline-none">
          </div>
        </div>

        <!-- Password -->
        <div class="space-y-xs">
          <label class="font-label-md text-label-md text-on-surface-variant block ml-xs" for="password"><%= t('auth.password') %></label>
          <div class="relative group">
            <span class="material-symbols-outlined absolute left-base top-1/2 -translate-y-1/2 text-on-surface-variant group-focus-within:text-tsubaki-red transition-colors">lock</span>
            <input id="password" name="password" type="password"
              placeholder="••••••••" required autocomplete="new-password"
              class="w-full pl-lg pr-lg py-base bg-surface-container-lowest border-0 border-b-2 border-outline-variant/30 focus:border-tsubaki-red focus:ring-0 rounded-lg transition-all font-body-md text-body-md text-charcoal-text outline-none">
            <button id="toggle-password" type="button"
              class="absolute right-base top-1/2 -translate-y-1/2 text-on-surface-variant hover:text-charcoal-text transition-colors"
              aria-label="<%= t('auth.show_hide_password') %>">
              <span id="toggle-password-icon" class="material-symbols-outlined">visibility</span>
            </button>
          </div>
        </div>

        <!-- Terms -->
        <div class="flex items-center space-x-base pt-xs">
          <input id="terms" name="terms" type="checkbox"
            class="rounded border-outline-variant text-tsubaki-red focus:ring-tsubaki-red w-4 h-4">
          <label class="font-caption text-caption text-on-surface-variant" for="terms">
            <%= t('auth.terms_agree') %>
            <a href="/terms" class="text-tsubaki-red hover:underline"><%= t('auth.terms_link') %></a>
            <%= lang === 'vi' ? 'và' : 'と' %>
            <a href="/privacy" class="text-tsubaki-red hover:underline"><%= t('auth.policy_link') %></a>
          </label>
        </div>

        <!-- Submit -->
        <button type="submit"
          class="w-full bg-tsubaki-red text-on-primary py-md rounded-xl font-h2 text-h2 hover:bg-primary transition-all active:scale-[0.98] shadow-lg shadow-tsubaki-red/20 mt-base">
          <%= t('auth.submit_register') %>
        </button>
      </form>

      <!-- Divider -->
      <div class="w-full flex items-center my-lg">
        <div class="flex-grow h-px bg-outline-variant/30"></div>
        <span class="px-md font-caption text-caption text-on-surface-variant/50"><%= t('auth.or_continue') %></span>
        <div class="flex-grow h-px bg-outline-variant/30"></div>
      </div>

      <!-- Social -->
      <button type="button" id="btn-google-register"
        class="w-full flex items-center justify-center gap-sm border border-outline-variant/50 rounded-lg py-base hover:bg-surface hover:shadow-sm transition-all font-label-md text-label-md text-charcoal-text active:scale-[0.98]">
        <svg width="18" height="18" viewBox="0 0 18 18" xmlns="http://www.w3.org/2000/svg">
          <path d="M17.64 9.2c0-.637-.057-1.251-.164-1.84H9v3.481h4.844c-.209 1.125-.843 2.078-1.796 2.717v2.258h2.908c1.702-1.567 2.684-3.875 2.684-6.615z" fill="#4285F4"/>
          <path d="M9 18c2.43 0 4.467-.806 5.956-2.18l-2.908-2.259c-.806.54-1.837.86-3.048.86-2.344 0-4.328-1.584-5.036-3.711H.957v2.332A8.997 8.997 0 009 18z" fill="#34A853"/>
          <path d="M3.964 10.71A5.41 5.41 0 013.682 9c0-.593.102-1.17.282-1.71V4.958H.957A8.996 8.996 0 000 9c0 1.452.348 2.827.957 4.042l3.007-2.332z" fill="#FBBC05"/>
          <path d="M9 3.58c1.321 0 2.508.454 3.44 1.345l2.582-2.58C13.463.891 11.426 0 9 0A8.997 8.997 0 00.957 4.958L3.964 7.29C4.672 5.163 6.656 3.58 9 3.58z" fill="#EA4335"/>
        </svg>
        Đăng ký với Google
      </button>

      <!-- Login link -->
      <div class="mt-lg text-center">
        <p class="font-body-md text-body-md text-on-surface-variant">
          <%= t('auth.has_account') %>
          <a href="/login" class="text-tsubaki-red font-semibold hover:underline ml-xs"><%= t('auth.login_link') %></a>
        </p>
      </div>

    </div>

    <!-- Ma quote -->
    <div class="mt-xl text-center opacity-40">
      <div class="inline-block p-lg rounded-full bg-surface-container-high/30 backdrop-blur-sm mb-md">
        <span class="material-symbols-outlined text-[48px] text-tsubaki-red/60">self_improvement</span>
      </div>
      <p class="font-caption text-caption italic text-on-surface-variant"><%= t('auth.zen_quote') %></p>
    </div>
  </main>

  <script src="/js/register.js"></script>
  <script src="https://cdn.jsdelivr.net/npm/@supabase/supabase-js@2/dist/umd/supabase.min.js"></script>
  <script>
  (function () {
    var SUPABASE_URL = '<%= supabaseUrl %>';
    var SUPABASE_KEY = '<%= supabaseKey %>';
    var BASE_URL     = '<%= process.env.BASE_URL || "http://localhost:3000" %>';

    document.getElementById('btn-google-register').addEventListener('click', async function () {
      var client = supabase.createClient(SUPABASE_URL, SUPABASE_KEY);
      var { error } = await client.auth.signInWithOAuth({
        provider: 'google',
        options: { redirectTo: BASE_URL + '/auth/callback' },
      });
      if (error) alert('Không thể đăng nhập với Google: ' + error.message);
    });
  })();
  </script>
</body>
</html>
